---
import Layout from "../layouts/Layout.astro";
import Starfield from "../components/Starfield.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Proof from "../components/Proof.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Starfield />
  <Nav />
  <Hero />
  <Services />
  <!-- <Proof /> hidden while updating featured businesses -->
  <Footer />

  <!-- ElevenLabs AI Profit Wizard — floating bubble, bottom-right -->
  <elevenlabs-convai
    agent-id="agent_3601kktqh8pfej0ayy03jfaj7z1b"
    avatar-orb-color-1="#e5b673"
    avatar-orb-color-2="#725ba7"
    action-text="Talk to our AI Strategist"
    start-call-text="Start Audit"
  ></elevenlabs-convai>
</Layout>
