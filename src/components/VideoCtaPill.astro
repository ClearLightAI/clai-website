---
/**
 * VARIANT 1 — "Floating pill" video CTA block.
 *
 * A ~90%-width floating rounded block (NOT full-bleed) carrying the ClearLight
 * hero gradient (navy -> purple -> navy), a gold-tinted border, atmosphere orbs
 * and a faint grid behind. 16:9 self-hosted video sits in a gold-glow "well" on
 * the left; CTA copy + gold button on the right.
 *
 * Bento language imported from the audit-report / publish-page system:
 *   - hero gradient, gold-tinted border, atmosphere orbs, faint grid
 *   - gold eyebrow with leading rule, .btn-gold primary action
 *
 * Props let the real poster/video URL drop in later.
 */
interface Props {
  poster?: string;
  videoSrc?: string;
  href?: string;
}
const {
  poster = "/video/russell-poster.svg",
  videoSrc = "",
  href = "https://audit.clearlightai.com",
} = Astro.props;
---

<section class="relative z-10 px-6 py-16 md:py-20">
  <div class="vcta-pill mx-auto">
    <!-- atmosphere -->
    <div class="vcta-orb vcta-orb-1" aria-hidden="true"></div>
    <div class="vcta-orb vcta-orb-2" aria-hidden="true"></div>
    <div class="vcta-grid" aria-hidden="true"></div>

    <div class="vcta-inner">
      <!-- LEFT: video well -->
      <div class="vcta-video-col">
        <div class="vcta-well">
          <button class="vcta-player" type="button" aria-label="Play video from Russell" data-video-src={videoSrc}>
            <img class="vcta-poster" src={poster} alt="A word from Russell" loading="lazy" />
            <span class="vcta-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M8 5.5v13l11-6.5-11-6.5z" fill="currentColor" />
              </svg>
            </span>
            <span class="vcta-duration">1:42</span>
          </button>
        </div>
      </div>

      <!-- RIGHT: CTA copy -->
      <div class="vcta-copy-col">
        <h2 class="vcta-head">
          Take the same process<br />
          <span class="vcta-gold">9-figure entrepreneurs run.</span>
        </h2>
        <p class="vcta-sub">
          Russell walks you through what the AI Readiness Audit uncovers, and why it's the
          first move every serious business should make. Then run yours, free.
        </p>
        <a class="vcta-btn" href={href}>
          Start Your Free Audit
          <span class="vcta-arrow" aria-hidden="true">&rarr;</span>
        </a>
        <p class="vcta-micro">10 minutes &middot; No cost &middot; $500 of value</p>
      </div>
    </div>
  </div>
</section>

<style>
  .vcta-pill {
    position: relative;
    width: 90%;
    max-width: 1180px;
    border-radius: 32px;
    padding: clamp(28px, 4vw, 56px);
    overflow: hidden;
    background: linear-gradient(165deg, #13123b 0%, #725ba7 58%, #13123b 100%);
    border: 1px solid rgba(229, 182, 115, 0.22);
    box-shadow:
      0 40px 120px -40px rgba(114, 91, 167, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.03) inset;
  }

  /* atmosphere */
  .vcta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
  }
  .vcta-orb-1 {
    width: 420px; height: 420px;
    background: rgba(75, 158, 215, 0.22);
    top: -160px; right: -120px;
  }
  .vcta-orb-2 {
    width: 380px; height: 380px;
    background: rgba(229, 182, 115, 0.14);
    bottom: -160px; left: -100px;
  }
  .vcta-grid {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background:
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px) 0 0 / 56px 56px,
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px) 0 0 / 56px 56px;
    mask-image: radial-gradient(ellipse 90% 90% at 30% 30%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 90% 90% at 30% 30%, #000 30%, transparent 80%);
  }

  .vcta-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  /* ===== video well ===== */
  .vcta-video-col { min-width: 0; }
  .vcta-well {
    position: relative;
    border-radius: 18px;
    padding: 10px;
    background: rgba(13, 12, 43, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .vcta-well::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 20px;
    background: radial-gradient(120% 120% at 50% 0%, rgba(229,182,115,0.35) 0%, transparent 60%);
    z-index: -1;
    filter: blur(10px);
  }
  .vcta-player {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 0;
    padding: 0;
    cursor: pointer;
    background: #0d0c2b;
  }
  .vcta-poster {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease;
  }
  .vcta-player:hover .vcta-poster { transform: scale(1.03); filter: brightness(1.05); }

  .vcta-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 76px; height: 76px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(229, 182, 115, 0.95);
    color: #13123b;
    box-shadow: 0 12px 40px -8px rgba(229, 182, 115, 0.7);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.35s ease;
  }
  .vcta-play svg { width: 30px; height: 30px; margin-left: 3px; }
  .vcta-player:hover .vcta-play {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 16px 50px -8px rgba(229, 182, 115, 0.85);
  }
  /* pulsing halo */
  .vcta-play::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(229, 182, 115, 0.6);
    animation: vctaPulse 2.6s ease-out infinite;
  }
  @keyframes vctaPulse {
    0% { transform: scale(1); opacity: 0.7; }
    70% { transform: scale(1.5); opacity: 0; }
    100% { opacity: 0; }
  }

  .vcta-duration {
    position: absolute;
    bottom: 12px; right: 12px;
    font-family: var(--font-display, "Garet", sans-serif);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(13, 12, 43, 0.7);
    padding: 4px 10px;
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }

  /* ===== copy ===== */
  .vcta-copy-col { min-width: 0; }
  .vcta-head {
    font-family: var(--font-display, "Garet", sans-serif);
    font-weight: 300;
    font-size: clamp(1.7rem, 3.2vw, 2.6rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 18px;
  }
  .vcta-gold { color: #e5b673; }
  .vcta-sub {
    font-size: 1rem;
    line-height: 1.62;
    color: rgba(240, 239, 245, 0.78);
    max-width: 460px;
    margin-bottom: 28px;
  }

  .vcta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #e5b673;
    color: #13123b;
    font-family: var(--font-display, "Garet", sans-serif);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    padding: 16px 34px;
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 10px 30px -8px rgba(229, 182, 115, 0.55);
    transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.22s ease, background 0.22s ease;
  }
  .vcta-btn:hover {
    background: #efc98c;
    transform: translateY(-3px);
    box-shadow: 0 16px 42px -8px rgba(229, 182, 115, 0.7);
  }
  .vcta-arrow { transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1); }
  .vcta-btn:hover .vcta-arrow { transform: translateX(4px); }

  .vcta-micro {
    margin-top: 16px;
    font-family: var(--font-display, "Garet", sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(229, 182, 115, 0.85);
  }

  /* ===== responsive ===== */
  @media (max-width: 860px) {
    .vcta-pill { width: 100%; border-radius: 24px; }
    .vcta-inner { grid-template-columns: 1fr; gap: 28px; }
    .vcta-copy-col { text-align: center; }
    .vcta-sub { margin-left: auto; margin-right: auto; }
    .vcta-play { width: 64px; height: 64px; }
    .vcta-play svg { width: 26px; height: 26px; }
  }
</style>
