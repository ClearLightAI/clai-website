---
/**
 * Minimal footer — CTA + copyright. No bloat.
 */
---

<footer class="relative z-10 border-t border-white/[0.04]">
  <!-- Final CTA -->
  <div class="py-20 px-6 text-center">
    <h2 class="font-display font-bold text-2xl md:text-3xl tracking-tight text-white mb-4">
      Ready to find your AI wins?
    </h2>
    <p class="text-text-secondary text-base mb-8 max-w-md mx-auto leading-relaxed">
      Start with a free assessment. No forms, no sales pitch — just clarity on where AI fits.
    </p>
    <a
      href="https://audit.clearlightai.com"
      class="inline-flex items-center gap-2 px-8 py-4 bg-gold text-[#0d0e2b] font-display font-bold text-sm tracking-[0.06em] uppercase rounded-lg hover:scale-[1.02] transition-transform"
    >
      Start Free Audit
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.04] py-6 px-6">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-text-tertiary text-xs">
      <span>&copy; 2026 ClearLight AI. All rights reserved.</span>
      <span>Built for performance. Architected for scale.</span>
    </div>
  </div>
</footer>
