---
/**
 * Starfield background — fixed canvas behind all content.
 * Includes a subtle purple glow that follows the cursor with a trailing tail.
 */
---

<div class="starfield-container">
  <canvas id="starfield-canvas"></canvas>
  <div id="cursor-glow" class="cursor-glow"></div>
  <div id="cursor-tail" class="cursor-tail"></div>
</div>

<script>
  import { createStarfield } from "../starfield.js";

  // Starfield
  const canvas = document.getElementById("starfield-canvas") as HTMLCanvasElement;
  if (canvas) {
    const sf = createStarfield(canvas, { speed: 0.7 });
    sf.start();
  }

  // Cursor-following purple glow with trailing tail
  const glow = document.getElementById("cursor-glow") as HTMLDivElement;
  const tail = document.getElementById("cursor-tail") as HTMLDivElement;
  if (glow && tail) {
    let targetX = window.innerWidth * 0.5;
    let targetY = window.innerHeight * 0.5;
    let glowX = targetX;
    let glowY = targetY;
    let tailX = targetX;
    let tailY = targetY;

    document.addEventListener("mousemove", (e) => {
      targetX = e.clientX;
      targetY = e.clientY;
    });

    function updateGlow() {
      // Main glow follows cursor with moderate lag
      glowX += (targetX - glowX) * 0.06;
      glowY += (targetY - glowY) * 0.06;
      glow.style.transform = `translate(${glowX - 250}px, ${glowY - 250}px)`;

      // Tail follows the glow with even more lag — creates trailing effect
      tailX += (glowX - tailX) * 0.03;
      tailY += (glowY - tailY) * 0.03;
      tail.style.transform = `translate(${tailX - 350}px, ${tailY - 350}px)`;

      requestAnimationFrame(updateGlow);
    }
    requestAnimationFrame(updateGlow);
  }
</script>

<style>
  .starfield-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .starfield-container canvas {
    width: 100%;
    height: 100%;
  }

  /* Main glow — tight, follows cursor closely */
  .cursor-glow {
    position: fixed;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(114, 91, 167, 0.10) 0%,
      rgba(114, 91, 167, 0.04) 30%,
      transparent 65%
    );
    filter: blur(30px);
    pointer-events: none;
    will-change: transform;
  }

  /* Trailing tail — larger, softer, lags behind */
  .cursor-tail {
    position: fixed;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(114, 91, 167, 0.06) 0%,
      rgba(75, 94, 167, 0.02) 35%,
      transparent 60%
    );
    filter: blur(50px);
    pointer-events: none;
    will-change: transform;
  }
</style>
