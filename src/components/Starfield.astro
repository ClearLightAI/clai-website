---
/**
 * Starfield background — fixed canvas behind all content.
 * Animation JS loads client-side only, deferred to avoid blocking paint.
 */
---

<div class="starfield-container">
  <canvas id="starfield-canvas"></canvas>

  <!-- Ambient nebula orbs — CSS only, no JS cost -->
  <div class="orb orb-gold"></div>
  <div class="orb orb-purple"></div>
  <div class="orb orb-blue"></div>
</div>

<script>
  import { createStarfield } from "../starfield.js";

  const canvas = document.getElementById(
    "starfield-canvas"
  ) as HTMLCanvasElement;
  if (canvas) {
    const sf = createStarfield(canvas, { speed: 0.7 });
    sf.start();
  }
</script>

<style>
  .starfield-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .starfield-container canvas {
    width: 100%;
    height: 100%;
  }

  /* Nebula orbs — soft animated glows, GPU-composited */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
    animation: orbFloat 24s ease-in-out infinite;
  }

  .orb-gold {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -180px;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(229, 182, 115, 0.1) 0%,
      rgba(229, 182, 115, 0.02) 40%,
      transparent 70%
    );
    filter: blur(60px);
  }

  .orb-purple {
    width: 500px;
    height: 500px;
    bottom: -120px;
    left: -180px;
    background: radial-gradient(
      circle at 60% 40%,
      rgba(114, 91, 167, 0.07) 0%,
      rgba(114, 91, 167, 0.015) 40%,
      transparent 70%
    );
    filter: blur(70px);
    animation-delay: -8s;
    animation-duration: 30s;
  }

  .orb-blue {
    width: 400px;
    height: 400px;
    top: 45vh;
    right: -100px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(75, 158, 215, 0.06) 0%,
      rgba(75, 158, 215, 0.01) 40%,
      transparent 70%
    );
    filter: blur(80px);
    animation-delay: -16s;
    animation-duration: 34s;
  }

  @keyframes orbFloat {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(20px, -30px) scale(1.04);
    }
    66% {
      transform: translate(-15px, 18px) scale(0.96);
    }
  }
</style>
