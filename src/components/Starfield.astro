---
/**
 * Starfield background — renders as a fixed canvas behind all content.
 * The animation JS loads client-side only, deferred to avoid blocking paint.
 */
---

<div class="starfield-container">
  <canvas id="starfield-canvas"></canvas>

  <!-- Ambient nebula orbs -->
  <div class="orb orb-gold"></div>
  <div class="orb orb-purple"></div>
  <div class="orb orb-blue"></div>
</div>

<script>
  import { createStarfield } from "../starfield.js";

  const canvas = document.getElementById(
    "starfield-canvas"
  ) as HTMLCanvasElement;
  if (canvas) {
    const sf = createStarfield(canvas, { speed: 0.6, trailLength: 0.8 });
    sf.start();
  }
</script>

<style>
  .starfield-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .starfield-container canvas {
    width: 100%;
    height: 100%;
  }

  /* Nebula orbs — soft animated glows */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform, opacity;
    animation: orbFloat 22s ease-in-out infinite;
  }

  .orb-gold {
    width: 700px;
    height: 700px;
    top: -250px;
    right: -200px;
    background: radial-gradient(
      circle at 40% 40%,
      rgba(229, 182, 115, 0.12) 0%,
      rgba(229, 182, 115, 0.03) 40%,
      transparent 70%
    );
    filter: blur(60px);
  }

  .orb-purple {
    width: 550px;
    height: 550px;
    bottom: -150px;
    left: -200px;
    background: radial-gradient(
      circle at 60% 40%,
      rgba(160, 130, 220, 0.08) 0%,
      rgba(140, 110, 200, 0.02) 40%,
      transparent 70%
    );
    filter: blur(70px);
    animation-delay: -8s;
    animation-duration: 28s;
  }

  .orb-blue {
    width: 450px;
    height: 450px;
    top: 40vh;
    right: -120px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(100, 160, 220, 0.07) 0%,
      rgba(100, 160, 220, 0.01) 40%,
      transparent 70%
    );
    filter: blur(80px);
    animation-delay: -15s;
    animation-duration: 32s;
  }

  @keyframes orbFloat {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    33% {
      transform: translate(25px, -35px) scale(1.06);
      opacity: 0.75;
    }
    66% {
      transform: translate(-18px, 20px) scale(0.94);
      opacity: 0.9;
    }
  }
</style>
