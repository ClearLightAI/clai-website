---
/**
 * Hero section — full viewport, centered.
 * Primary CTA: link to audit.clearlightai.com
 */
---

<section class="relative z-10 min-h-screen flex items-center justify-center px-6 pt-20 pb-16">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Eyebrow -->
    <div
      class="animate-fade-up delay-1 inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-lavender/20 bg-lavender/[0.04] mb-10"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span>
      <span class="font-display text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-lavender/70">
        AI Readiness Assessment
      </span>
    </div>

    <!-- Headline -->
    <h1
      class="animate-fade-up delay-2 font-display font-bold text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.02] tracking-[-0.04em] text-white mb-6"
    >
      What's the ROI on AI
      <span class="text-gradient-brand">in your business?</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-up delay-3 text-lg md:text-xl leading-relaxed text-text-secondary max-w-xl mx-auto mb-12">
      Take the same assessment trusted by nine-figure businesses and learn where you can forge ahead.
    </p>

    <!-- Primary CTA — gold pop accent, like the tagline in the logo -->
    <div class="animate-fade-up delay-4 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://audit.clearlightai.com"
        class="group inline-flex items-center gap-3 px-8 py-4 bg-gold text-[#0d0e2b] font-display font-bold text-sm tracking-[0.06em] uppercase rounded-lg hover:scale-[1.02] transition-transform"
      >
        Start Free Audit
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <span class="text-text-tertiary text-sm">10 minutes. No cost. Instant results.</span>
    </div>
  </div>
</section>
