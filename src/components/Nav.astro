---
/**
 * Minimal fixed nav — logo image + CTA. Transparent, blends with starfield.
 */
---

<nav
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-12 py-4"
>
  <a href="/">
    <img src="/logo.png" alt="ClearLight AI" class="h-8 md:h-10" />
  </a>

  <a
    href="https://audit.clearlightai.com"
    class="inline-flex items-center gap-2 px-5 py-2.5 font-display font-light text-xs tracking-[0.08em] uppercase rounded-md text-white hover:scale-[1.02] transition-transform"
    style="background: linear-gradient(135deg, #745aa5, #7789d9);"
  >
    Free Audit
  </a>
</nav>
