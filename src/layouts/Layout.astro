---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ClearLight AI | What's the ROI on AI in Your Business?",
  description = "Take the same AI readiness assessment trusted by 7-, 8- and 9-figure businesses. Discover where AI fits and what to build first.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://unpkg.com/@elevenlabs/convai-widget-embed"
      async
      type="text/javascript"></script>
  </head>
  <body class="grain">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
