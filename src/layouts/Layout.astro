---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ClearLight AI | What's the ROI on AI in Your Business?",
  description = "Take the same assessment trusted by nine-figure businesses and learn where you can forge ahead.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Open Graph / Social previews -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://clearlightai.com/og-image.png" />
    <meta property="og:url" content="https://clearlightai.com" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://clearlightai.com/og-image.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Garet (display) via CDNFonts -->
    <link
      href="https://fonts.cdnfonts.com/css/garet"
      rel="stylesheet"
    />
    <!-- Nunito Sans Expanded (body) via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,opsz,wdth,wght@0,6..12,100,300;0,6..12,100,400;0,6..12,100,600;0,6..12,100,700;0,6..12,125,300;0,6..12,125,400;0,6..12,125,600;0,6..12,125,700;1,6..12,125,400&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://unpkg.com/@elevenlabs/convai-widget-embed"
      async
      type="text/javascript"></script>
  </head>
  <body class="grain">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
